# ==============================================================================
# LNG-GeoEnv Environment Configuration
# 
# Copy this file to .env and fill in your actual values
# .env is in .gitignore and will NOT be committed
# ==============================================================================

# ===== API CREDENTIALS (REQUIRED) =====
# Choose ONE of these methods:
# Method 1: Direct Gemini API Key
GEMINI_API_KEY=<your_gemini_api_key_here>

# Method 2: Hugging Face Token (fallback)
HF_TOKEN=<you_hf_token_here>
API_BASE_URL=https://router.huggingface.co/v1
MODEL_NAME=deepseek-ai/DeepSeek-R1-Distill-Qwen- #choose a model from https://huggingface.co/models?filter=deepseek
# ===== GEMINI MODEL CONFIGURATION =====
# Model to use
# MODEL_NAME=gemini-2.5-flash

# API Rate Limits for Gemini
# RPM: Requests Per Minute
# TPM: Tokens Per Minute  
# RPD: Requests Per Day
GEMINI_RPM=5
GEMINI_TPM=250000
GEMINI_RPD=20

# Temperature: 0.0 (deterministic) to 2.0 (creative)
# Recommended: 0.5-0.9 for strategic decision making
AGENT_TEMPERATURE=0.7

# Maximum tokens in response
AGENT_MAX_TOKENS=500

# Request timeout in seconds
AGENT_TIMEOUT=30

# ===== AGENT CONFIGURATION =====
# Enable/disable the LLM agent (1=enabled, 0=disabled)
AGENT_ENABLED=1

# ===== LOGGING =====
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Optional: Log to file (leave blank for console only)
# LOG_FILE=./logs/agent.log

# ===== ENVIRONMENT =====
# Environment: local, staging, production
ENV=local

# Debug mode (1=enabled, 0=disabled)
DEBUG=0

# ==============================================================================
# SETUP INSTRUCTIONS
# ==============================================================================
#
# 1. Get your Gemini API key from: https://aistudio.google.com/app/apikeys
#
# 2. Copy this file:
#    cp .env.example .env
#
# 3. Edit .env and add your API key:
#    GEMINI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
#
# 4. Run the agent:
#    python main.py
#
# ==============================================================================
